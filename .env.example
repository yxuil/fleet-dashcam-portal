APP_ENV=dev

# Database
DATABASE_URL=postgresql+asyncpg://dashcam:dashcam@localhost:5432/dashcam

# JWT
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256

# Storage backend selection: local | s3
# In dev the default is `local` — clip MP4s live on disk under STORAGE_ROOT
# and playback is served by GET /clips/{id}/stream. Flip to `s3` to use
# MinIO/S3 with SigV4 presigned URLs (and keep the docker compose MinIO
# service running).
STORAGE_BACKEND=local
STORAGE_ROOT=./var/clips

# S3 / MinIO — only used when STORAGE_BACKEND=s3.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=dashcam-clips
S3_REGION=us-east-1
