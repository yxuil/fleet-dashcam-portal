# Frontend environment variables (read by Vite at build/dev time).
# Copy to `.env.local` and adjust as needed.

# Base URL for the backend API. The Vite dev server runs on :5173; the
# backend defaults to :8000. CORS on the backend allows :5173.
VITE_API_BASE=http://localhost:8000

# Either "dev" or "prod". In "dev" the app shows a DevUserPicker in the
# corner and `getAuthHeaders()` mints `X-Dev-User-Id` / `X-Dev-Tenant-Id`
# instead of expecting an upstream Authorization header.
VITE_APP_ENV=dev
